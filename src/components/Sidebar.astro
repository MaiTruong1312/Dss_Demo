---
const steps = [
  { id: 0, title: "Giới thiệu", path: "/" },
  { id: 1, title: "1. Khởi tạo Khóa", path: "/step1-keygen" },
  { id: 2, title: "2. Trao đổi Khóa", path: "/step2-exchange" },
  { id: 3, title: "3. Băm SHA-256", path: "/step3-hashing" },
  { id: 4, title: "4. Ký số ECDSA", path: "/step4-signing" },
  { id: 5, title: "5. Mã hóa AES", path: "/step5-encryption" },
  { id: 6, title: "6. Truyền tải", path: "/step6-transmission" },
  { id: 7, title: "7. Xác thực", path: "/step7-verification" },
];

const { currentStep = 0 } = Astro.props;
---

<aside class="w-72 bg-slate-900/50 border-r border-white/10 h-screen sticky top-0 flex flex-col p-6 overflow-y-auto">
  <div class="mb-8">
    <h2 class="text-xl font-black text-white italic tracking-tighter">
      CRYPTO <span class="text-cyan-400">WIZARD</span>
    </h2>
    <p class="text-xs text-slate-500 mt-1 uppercase tracking-widest font-bold">Simulation 7.0</p>
  </div>

  <nav class="flex-1 space-y-2">
    {steps.map((s) => (
      <a
        href={s.path}
        class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all group ${
          currentStep === s.id
            ? "bg-cyan-500/10 border border-cyan-500/20 text-cyan-400"
            : "text-slate-400 hover:bg-white/5 hover:text-slate-200"
        }`}
      >
        <div class={`w-6 h-6 rounded-lg flex items-center justify-center text-[10px] font-black border transition-colors ${
          currentStep === s.id ? "bg-cyan-500 text-slate-950 border-cyan-400" : "bg-slate-950 border-slate-800 text-slate-600 group-hover:border-slate-600"
        }`}>
          {s.id}
        </div>
        <span class="text-sm font-semibold">{s.title}</span>
      </a>
    ))}
  </nav>

  <div class="mt-8 pt-6 border-t border-white/5">
    <button 
        id="reset-simulation"
        class="w-full py-3 bg-red-500/10 border border-red-500/20 text-red-500 text-xs font-black rounded-xl hover:bg-red-500/20 transition-all flex items-center justify-center gap-2"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
        RESET TOÀN BỘ
    </button>
  </div>
</aside>

<script>
    import { resetState } from '../utils/state.js';
    document.getElementById('reset-simulation')?.addEventListener('click', () => {
        if (confirm('Bạn có chắc chắn muốn xóa toàn bộ tiến trình và bắt đầu lại?')) {
            resetState();
            window.location.href = '/';
        }
    });
</script>
