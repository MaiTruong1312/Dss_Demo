---
import SimulationLayout from '../layouts/SimulationLayout.astro';
---

<SimulationLayout title="BƯỚC 5: Mã hóa AES - Crypto Wizard" currentStep={5}>
  <div class="space-y-8 pb-20">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-black text-white">BƯỚC 5: Mã hóa Dữ liệu (AES-GCM)</h1>
        <p class="text-slate-400">Khám phá cỗ máy toán học biến dữ liệu của bạn thành "rác" mật mã.</p>
      </div>
      <div id="status-tag" class="px-4 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full text-[10px] font-black uppercase text-amber-500 tracking-widest">
        Chờ bắt đầu
      </div>
    </div>

    <!-- MAIN ENGINE CARD -->
    <div class="step-card border-blue-500/10 overflow-hidden relative">
        <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-blue-500/5 rounded-full blur-3xl"></div>
        
        <div class="flex flex-col lg:flex-row gap-8 items-center relative z-10">
            <!-- 4x4 State Matrix Visual -->
            <div class="space-y-4">
                <div class="text-[10px] uppercase font-black tracking-widest text-blue-400 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>
                    AES State Matrix (128-bit blocks)
                </div>
                <div id="state-matrix" class="grid grid-cols-4 gap-2 bg-slate-950 p-4 rounded-2xl border border-white/5 shadow-2xl">
                    {Array.from({length: 16}).map((_, i) => (
                        <div id={`cell-${i}`} class="w-10 h-10 md:w-12 md:h-12 bg-white/5 border border-white/10 rounded-lg flex items-center justify-center text-[10px] md:text-xs font-mono text-slate-500 transition-all duration-300">
                            00
                        </div>
                    ))}
                </div>
            </div>

            <!-- Transformation Status -->
            <div class="flex-1 space-y-6 w-full">
                <div class="space-y-4">
                    <div class="flex justify-between items-end">
                        <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tiến trình 10 Rounds (AES-128)</div>
                        <div id="round-number" class="text-2xl font-serif italic text-blue-400 transition-all duration-500">Round 0</div>
                    </div>
                    <div class="h-2 bg-white/5 rounded-full overflow-hidden">
                        <div id="round-progress" class="h-full bg-blue-500 transition-all duration-500 w-0"></div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    {[
                        { id: 'sub-bytes', label: '1. SubBytes', desc: 'Thế byte qua S-Box', icon: 'M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7' },
                        { id: 'shift-rows', label: '2. ShiftRows', desc: 'Dịch chuyển hàng', icon: 'm15 15 5 5M4 4l5 5m0 6-5 5m16-16-5 5' },
                        { id: 'mix-cols', label: '3. MixColumns', desc: 'Trộn cột toán học', icon: 'M21 12H3M12 3v18' },
                        { id: 'add-key', label: '4. AddRoundKey', desc: 'Cộng khóa vòng (XOR)', icon: 'M12 5v14M5 12h14' }
                    ].map(step => (
                        <div id={`step-${step.id}`} class="p-3 bg-white/5 border border-white/5 rounded-xl opacity-20 transition-all group/step border-l-2 border-l-transparent">
                            <div class="flex items-center gap-2 mb-0.5">
                                <svg class="text-blue-400" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d={step.icon}/></svg>
                                <div class="text-[10px] font-black text-white">{step.label}</div>
                            </div>
                            <div class="text-[8px] text-slate-500 italic leading-tight">{step.desc}</div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <!-- MATH DEEP DIVE SECTION (Lab) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- XOR Laboratory -->
        <div class="step-card bg-slate-900/40 border-indigo-500/10 space-y-4">
            <div class="text-[10px] uppercase font-black tracking-widest text-indigo-400">Phòng thí nghiệm XOR (Exclusive Or)</div>
            <div class="p-4 bg-slate-950 rounded-2xl border border-white/5 space-y-4 font-mono text-[10px]">
                <div class="flex items-center justify-between group">
                    <span class="text-slate-500">Dữ liệu thô:</span>
                    <span id="xor-data" class="text-white">1010 1100</span>
                </div>
                <div class="flex items-center justify-between group">
                    <span class="text-slate-500">Khóa bí mật:</span>
                    <span id="xor-key" class="text-blue-400">1100 0011</span>
                </div>
                <div class="h-px bg-white/5"></div>
                <div class="flex items-center justify-between group">
                    <span class="text-indigo-400 font-bold">Kết quả (⊕):</span>
                    <span id="xor-result" class="bg-indigo-500/20 px-2 py-0.5 rounded text-indigo-300 font-black">0110 1111</span>
                </div>
                <p class="text-[8px] text-slate-500 leading-normal italic mt-2">
                    * Trong AddRoundKey, ta lấy từng bit của dữ liệu cộng (XOR) với khóa. 
                    Nếu giống nhau ra 0, khác nhau ra 1. Đây là cách "khóa" dữ liệu.
                </p>
            </div>
        </div>

        <!-- S-Box Preview -->
        <div class="step-card bg-slate-900/40 border-purple-500/10 space-y-4">
            <div class="text-[10px] uppercase font-black tracking-widest text-purple-400">Bảng tra cứu S-Box (Substitution)</div>
            <div class="flex items-center gap-6 p-4 bg-slate-950 rounded-2xl border border-white/5">
                <div class="flex flex-col items-center gap-1">
                    <div class="text-[8px] text-slate-500">Vào</div>
                    <div id="sbox-in" class="w-8 h-8 bg-white/5 rounded border border-white/10 flex items-center justify-center text-white text-xs">A4</div>
                </div>
                <div class="animate-pulse">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-purple-500"><path d="m9 18 6-6-6-6"/></svg>
                </div>
                <!-- Mini Table -->
                <div class="grid grid-cols-4 gap-1 p-1 bg-white/5 rounded">
                    {Array.from({length: 16}).map((_, i) => (
                        <div id={`sbox-cell-${i}`} class="w-3 h-3 rounded-[2px] bg-slate-800 transition-colors duration-200"></div>
                    ))}
                </div>
                <div class="animate-pulse">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-purple-500"><path d="m9 18 6-6-6-6"/></svg>
                </div>
                <div class="flex flex-col items-center gap-1">
                    <div class="text-[8px] text-slate-500">Ra</div>
                    <div id="sbox-out" class="w-8 h-8 bg-purple-500/20 rounded border border-purple-500/40 flex items-center justify-center text-purple-400 text-xs font-black">49</div>
                </div>
            </div>
             <p class="text-[8px] text-slate-500 leading-normal italic">
                * SubBytes thay thế từng byte để làm xáo trộn mối liên hệ phi tuyến tính.
             </p>
        </div>
    </div>

    <!-- Input/Output View -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="step-card border-white/5 space-y-6">
        <div class="text-[10px] uppercase font-black tracking-widest text-slate-400">Nội dung thô trước mã hóa</div>
        <div class="bg-slate-950 p-6 rounded-2xl border border-white/5 space-y-4">
            <div class="space-y-1">
                <div id="raw-msg" class="text-xs text-white leading-relaxed break-all font-mono opacity-50"></div>
            </div>
            <div class="p-3 bg-emerald-500/5 border border-emerald-500/10 rounded-xl flex items-center justify-between">
                <div class="text-[9px] font-black text-emerald-500 uppercase">AES KEY (SHA-256 of SS)</div>
                <div id="shared-secret-status" class="text-[10px] font-mono text-emerald-500/50 italic">••••••••••••••••</div>
            </div>
        </div>
      </div>

      <div class="step-card border-blue-500/10 space-y-6 flex flex-col justify-between">
        <div class="text-[10px] uppercase font-black tracking-widest text-blue-500">Bản mã AES-GCM (Payload)</div>
        <div id="cipher-box" class="bg-slate-950 p-6 rounded-2xl border border-white/5 font-mono text-[10px] break-all leading-normal flex items-center justify-center italic text-slate-600 min-h-[140px] text-center">
            Mã băm và chữ ký sẽ được mã hóa tại đây...
        </div>
        <div id="cipher-final" class="hidden">
             <div class="p-3 bg-blue-500/5 border border-blue-500/10 rounded-xl flex items-center justify-between">
                <div class="text-[8px] font-black text-blue-400 uppercase">Initialization Vector (IV)</div>
                <div id="final-iv" class="text-[9px] text-blue-300 font-mono"></div>
             </div>
        </div>
      </div>
    </div>

    <!-- Action Area -->
    <div class="flex justify-center flex-col items-center gap-4">
       <button id="action-btn" class="px-12 py-5 bg-white text-slate-950 font-black rounded-2xl hover:bg-blue-400 transition-all shadow-2xl flex items-center gap-3 group">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span>CHẠY CỖ MÁY TOÁN HỌC AES</span>
        </button>
    </div>

    <!-- Detailed Accordion -->
    <div class="max-w-4xl mx-auto space-y-4">
        <details class="group bg-slate-900/50 border border-white/5 rounded-3xl overflow-hidden shadow-xl" open>
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-white/5 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400">
                         <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><path d="m11 11 3 3-4 4 10-10L14 4z"/></svg>
                    </div>
                    <span class="font-black text-xs uppercase tracking-widest text-slate-200">Dễ hiểu hơn về toán học AES</span>
                </div>
                <svg class="w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="px-8 pb-8 space-y-8 text-sm text-slate-400 leading-relaxed text-justify md:columns-2 gap-12">
                <div class="space-y-3">
                    <h4 class="font-black text-blue-400 text-xs uppercase">1. TẠI SAO LẠI CẦN 10 VÒNG?</h4>
                    <p>Nếu chỉ mã hóa 1 vòng, kẻ tấn công có thể dùng toán học để suy ngược lại khóa. Việc lặp lại **10 vòng** giống như việc bạn nhào bột 10 lần: càng nhào kỹ, các nguyên liệu (dữ liệu và khóa) càng hòa quyện vào nhau đến mức không thể tách rời.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-indigo-400 text-xs uppercase">2. PHÉP TOÁN XOR (⊕) - "CHÌA KHÓA"</h4>
                    <p>XOR là phép toán kỳ diệu nhất của mật mã học. Nếu bạn XOR dữ liệu với Khóa, bạn có Bản mã. Nếu bạn lấy Bản mã XOR lại với Khóa một lần nữa, bạn sẽ có lại Dữ liệu gốc! Nó vừa là ổ khóa, vừa là chìa khóa.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-purple-400 text-xs uppercase">3. S-BOX - "BẢN MÃ HÓA"</h4>
                    <p>SubBytes sử dụng một bảng tra cứu gọi là S-Box. Đây là một hàm phi tuyến tính cực kỳ phức tạp. Mục tiêu là để đảm bảo rằng không có bất kỳ quy luật toán học đơn giản nào có thể mô tả được sự thay đổi của byte đầu vào.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-cyan-400 text-xs uppercase">4. TÍNH TOÀN VẸN CỦA GCM</h4>
                    <p>Trong chế độ GCM, sau khi mã hóa, hệ thống còn tính toán một giá trị gọi là **Authentication Tag**. Nó hoạt động giống như một chiếc kẹp chì trên công-ten-nơ: Nếu ai đó mở ra và sửa dữ liệu, kẹp chì sẽ bị gãy và người nhận sẽ biết ngay.</p>
                </div>
            </div>
        </details>
    </div>
  </div>
</SimulationLayout>

<script>
  import { encryptAES, bufferToHex, hexToBuffer } from '../utils/crypto.js';
  import { loadState, saveState } from '../utils/state.js';

  const actionBtn = document.getElementById('action-btn');
  const rawMsgDisp = document.getElementById('raw-msg');
  const sharedStatus = document.getElementById('shared-secret-status');
  const statusTag = document.getElementById('status-tag');
  
  const matrixCells = Array.from({length: 16}).map((_, i) => document.getElementById(`cell-${i}`));
  const roundText = document.getElementById('round-number');
  const roundBar = document.getElementById('round-progress');
  
  const stepSub = document.getElementById('step-sub-bytes');
  const stepShift = document.getElementById('step-shift-rows');
  const stepMix = document.getElementById('step-mix-cols');
  const stepAdd = document.getElementById('step-add-key');

  const xorData = document.getElementById('xor-data');
  const xorResult = document.getElementById('xor-result');
  const sboxIn = document.getElementById('sbox-in');
  const sboxOut = document.getElementById('sbox-out');
  const sboxCells = Array.from({length: 16}).map((_, i) => document.getElementById(`sbox-cell-${i}`));

  const cipherBox = document.getElementById('cipher-box');
  const cipherFinal = document.getElementById('cipher-final');
  const finalIv = document.getElementById('final-iv');

  async function init() {
    const state = await loadState();
    const payload = JSON.stringify({ m: state.msg, s: state.signatureHex });
    rawMsgDisp.textContent = payload.substring(0, 100) + "...";
    sharedStatus.textContent = state.aesKeyHex ? state.aesKeyHex.substring(0, 24).toUpperCase() + "..." : "SHARED_KEY_MISSING";
    
    if (state.ciphertextHex) {
        statusTag.textContent = "Đã mã hóa ✅";
        statusTag.classList.replace("bg-amber-500/10", "bg-emerald-500/10");
        statusTag.classList.replace("text-amber-500", "text-emerald-500");

        matrixCells.forEach(cell => {
            cell.textContent = randomHex();
            cell.classList.add('text-blue-400', 'bg-blue-500/5', 'border-blue-500/20');
        });

        roundText.textContent = `Round 10`;
        roundBar.style.width = `100%`;

        cipherBox.textContent = state.ciphertextHex.toUpperCase();
        cipherBox.classList.remove('italic', 'text-slate-600');
        cipherBox.classList.add('text-white', 'font-black');
        
        cipherFinal.classList.remove('hidden');
        finalIv.textContent = state.ivHex.toUpperCase();

        actionBtn.innerHTML = `
          <span>TIẾP TỤC ĐẾN BƯỚC 6</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        `;
        actionBtn.classList.replace('bg-white', 'bg-emerald-500');
        actionBtn.onclick = () => window.location.href = '/step6-transmission';
    } else {
        matrixCells.forEach(cell => cell.textContent = "00");
    }
  }

  function randomHex() { return Math.floor(Math.random() * 256).toString(16).padStart(2, '0').toUpperCase(); }
  function randomBin() { return Array.from({length: 8}, () => Math.round(Math.random())).join('').match(/.{4}/g).join(' '); }

  actionBtn?.addEventListener('click', async () => {
    actionBtn.disabled = true;
    const state = await loadState();
    
    if (!state.aesKeyHex || !state.msg) {
        alert('Thiếu AES Key! Hãy hoàn thành Bước 3.');
        window.location.href = '/step3-hashing';
        return;
    }

    statusTag.textContent = "Đang mã hóa SPN";
    statusTag.classList.replace("bg-amber-500/10", "bg-blue-500/10");
    statusTag.classList.replace("text-amber-500", "text-blue-500");

    // --- AES ROUND ANIMATION ---
    const totalRounds = 10;
    for (let r = 0; r <= totalRounds; r++) {
        roundText.textContent = `Round ${r}`;
        roundBar.style.width = `${(r / totalRounds) * 100}%`;
        
        // Randomize matrix cells
        matrixCells.forEach(cell => {
            cell.textContent = randomHex();
            cell.classList.add('text-blue-400', 'bg-blue-500/5', 'border-blue-500/20');
        });

        // Cycle through steps and Update Labs
        const steps = [
            { id: stepSub, lab: () => {
                sboxIn.textContent = randomHex();
                sboxOut.textContent = randomHex();
                sboxCells.forEach(c => c.classList.remove('bg-purple-500'));
                sboxCells[Math.floor(Math.random()*16)].classList.add('bg-purple-500');
            }},
            { id: stepShift, lab: () => {} },
            { id: stepMix, lab: () => {} },
            { id: stepAdd, lab: () => {
                xorData.textContent = randomBin();
                xorResult.textContent = randomBin();
            }}
        ];

        for (const s of steps) {
            s.id.classList.remove('opacity-20', 'border-l-transparent');
            s.id.classList.add('opacity-100', 'bg-blue-500/10', 'border-blue-400');
            s.lab();
            await new Promise(res => setTimeout(res, r === totalRounds ? 200 : 100));
            s.id.classList.add('opacity-20', 'border-l-transparent');
            s.id.classList.remove('bg-blue-500/10', 'border-blue-400');
        }
        
        await new Promise(res => setTimeout(res, 50));
    }

    // Actual Encryption
    const payload = JSON.stringify({ m: state.msg, s: state.signatureHex });
    const sharedKey = await window.crypto.subtle.importKey(
        'raw', 
        hexToBuffer(state.aesKeyHex),
        { name: "AES-GCM" }, 
        false, 
        ["encrypt"]
    );
    
    const { ciphertext, iv } = await encryptAES(sharedKey, payload);
    const cipherHex = bufferToHex(ciphertext);
    const ivHex = bufferToHex(iv);

    state.ciphertextHex = cipherHex;
    state.ivHex = ivHex;
    state.step = 6;
    await saveState(state);

    // Finalize
    cipherBox.textContent = cipherHex.toUpperCase();
    cipherBox.classList.remove('italic', 'text-slate-600');
    cipherBox.classList.add('text-white', 'font-black');
    
    cipherFinal.classList.remove('hidden');
    finalIv.textContent = ivHex.toUpperCase();

    statusTag.textContent = "Đã mã hóa ✅";
    statusTag.classList.replace("bg-blue-500/10", "bg-emerald-500/10");
    statusTag.classList.replace("text-blue-500", "text-emerald-500");

    actionBtn.innerHTML = `
      <span>TIẾP TỤC ĐẾN BƯỚC 6</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
    `;
    actionBtn.classList.replace('bg-white', 'bg-emerald-500');
    actionBtn.disabled = false;
    actionBtn.onclick = () => window.location.href = '/step6-transmission';
  });

  window.addEventListener('DOMContentLoaded', init);
</script>
