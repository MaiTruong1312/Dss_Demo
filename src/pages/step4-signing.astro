---
import SimulationLayout from '../layouts/SimulationLayout.astro';
---

<SimulationLayout title="BƯỚC 4: Ký số ECDSA - Crypto Wizard" currentStep={4}>
  <div class="space-y-8 pb-20">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-black text-white">BƯỚC 4: Tạo Chữ ký số (Digital Signature)</h1>
        <p class="text-slate-400">Alice sử dụng Private Key của mình để "đóng dấu" bảo mật lên mã băm.</p>
      </div>
      <div id="status-tag" class="px-4 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full text-[10px] font-black uppercase text-amber-500 tracking-widest">
        Chờ bắt đầu
      </div>
    </div>

    <!-- The Signature Engine Visualization -->
    <div class="step-card border-purple-500/10 relative overflow-hidden">
        <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-purple-500/5 rounded-full blur-3xl"></div>
        
        <div class="text-[10px] uppercase font-black tracking-widest text-purple-400 mb-8 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Cỗ máy Ký số ECDSA (Signature Engine)
        </div>

        <div class="flex flex-col lg:flex-row items-center justify-between gap-12 relative z-10">
            <!-- Inputs -->
            <div class="space-y-6 w-full lg:w-72">
                <div class="p-4 bg-slate-950 rounded-2xl border border-amber-500/20 relative group">
                    <div class="text-[8px] font-black text-amber-500 uppercase absolute -top-2 left-4 bg-slate-950 px-2">Mã băm (z)</div>
                    <div id="hash-display" class="text-[10px] font-mono text-slate-400 break-all line-clamp-2 italic">Loading hash...</div>
                </div>
                <div class="p-4 bg-slate-950 rounded-2xl border border-red-500/20 relative group">
                    <div class="text-[8px] font-black text-red-500 uppercase absolute -top-2 left-4 bg-slate-950 px-2">Alice's Private Key (d)</div>
                    <div id="d-display" class="text-[10px] font-mono text-slate-400 break-all line-clamp-1 italic">••••••••••••••••</div>
                </div>
                <div class="p-4 bg-slate-950 rounded-2xl border border-blue-500/20 relative group">
                    <div class="text-[8px] font-black text-blue-500 uppercase absolute -top-2 left-4 bg-slate-950 px-2">Random Nonce (k)</div>
                    <div id="k-display" class="text-[10px] font-mono text-slate-500 italic">Tạo ngẫu nhiên mỗi lần ký...</div>
                </div>
            </div>

            <!-- The Engine -->
            <div id="engine-core" class="relative group">
                <div class="w-24 h-24 bg-gradient-to-br from-purple-500 to-indigo-600 rounded-3xl flex items-center justify-center text-white shadow-2xl relative z-10 transition-all duration-500 overflow-hidden">
                    <svg id="engine-icon" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.77 3.77z"/></svg>
                    <div id="engine-glow" class="absolute inset-0 bg-white opacity-0 transition-opacity duration-300"></div>
                </div>
                <!-- Math Lines -->
                <div class="absolute inset-0 -scale-150 opacity-10 blur-xl bg-purple-500 rounded-full animate-pulse"></div>
            </div>

            <!-- Output: (r, s) -->
            <div class="space-y-6 w-full lg:w-96">
                <div class="bg-slate-950 border border-purple-500/20 p-6 rounded-3xl space-y-4">
                    <div class="text-[10px] font-black text-purple-400 uppercase tracking-widest text-center">Chữ ký số (r, s)</div>
                    <div id="sig-output" class="font-mono text-xs text-white text-center break-all leading-relaxed min-h-[60px] flex items-center justify-center italic text-slate-600">
                        Sẵn sàng để đóng dấu...
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="flex-1 h-px bg-white/5"></div>
                    <div class="text-[9px] font-black text-slate-500 uppercase">DSS Standard</div>
                    <div class="flex-1 h-px bg-white/5"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Comparison Table -->
    <div class="max-w-4xl mx-auto overflow-hidden rounded-3xl border border-white/5 bg-slate-900/50 shadow-2xl">
        <table class="w-full text-left text-xs border-collapse">
            <thead>
                <tr class="bg-white/5 text-[10px] font-black uppercase text-slate-400 tracking-widest">
                    <th class="p-6 border-b border-white/5">Bước</th>
                    <th class="p-6 border-b border-white/5">Thành phần sử dụng</th>
                    <th class="p-6 border-b border-white/5">Mục đích</th>
                </tr>
            </thead>
            <tbody class="text-slate-300">
                <tr class="hover:bg-white/[0.02] transition-colors">
                    <td class="p-6 border-b border-white/5 font-bold text-cyan-400">Bước 1 & 2</td>
                    <td class="p-6 border-b border-white/5 italic">ECDH Keys (Public/Private)</td>
                    <td class="p-6 border-b border-white/5">Để Alice và Bob có "khóa chung" (Shared Secret).</td>
                </tr>
                <tr class="hover:bg-white/[0.02] transition-colors">
                    <td class="p-6 border-b border-white/5 font-bold text-amber-400">Bước 3</td>
                    <td class="p-6 border-b border-white/5 italic">SHA-256 Algorithm</td>
                    <td class="p-6 border-b border-white/5">Để gom dữ liệu thành một "dấu vân tay" ngắn gọn.</td>
                </tr>
                <tr class="hover:bg-white/[0.02] transition-colors">
                    <td class="p-6 font-bold text-purple-400">Bước 4</td>
                    <td class="p-6 italic">ECDSA Private Key</td>
                    <td class="p-6">Dùng dấu vân tay đó để tạo ra "con dấu" bảo mật.</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Control Area -->
    <div class="flex justify-center flex-col items-center gap-4">
       <button id="action-btn" class="px-12 py-5 bg-white text-slate-950 font-black rounded-2xl hover:bg-purple-400 transition-all shadow-2xl flex items-center gap-3 group">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 22v-4"/><path d="M12 8V2"/><path d="M16.24 7.76l2.12-2.12"/><path d="M5.64 18.36l2.12-2.12"/><path d="M18.36 18.36l-2.12-2.12"/><path d="M7.76 7.76L5.64 5.64"/><path d="M22 12h-4"/><path d="M6 12H2"/></svg>
          <span>KÝ DỮ LIỆU (DIGITAL SIGN)</span>
        </button>
    </div>

    <!-- Educational Content Accordion (User's Text) -->
    <div class="max-w-4xl mx-auto space-y-4">
        <details class="group bg-slate-900/50 border border-white/5 rounded-3xl overflow-hidden shadow-xl" open>
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-white/5 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-purple-500/20 flex items-center justify-center text-purple-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <span class="font-black text-xs uppercase tracking-widest text-slate-200">Chữ ký số hoạt động như thế nào?</span>
                </div>
                <svg class="w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="px-8 pb-8 space-y-8 text-sm text-slate-400 leading-relaxed text-justify">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <h4 class="font-black text-purple-400 text-xs uppercase">1. CHỮ KÝ SỐ LÀ GÌ?</h4>
                        <p>Hãy tưởng tượng file bạn gửi đi là một bức thư. Mã băm (Hash) là bản tóm tắt nội dung. Chữ ký số là việc Alice dùng <strong>"con dấu riêng"</strong> đóng lên bản tóm tắt đó để chứng minh:</p>
                        <ul class="space-y-1 mt-2">
                            <li>✅ <strong>Xác thực:</strong> Bức thư này đúng là do Alice viết.</li>
                            <li>✅ <strong>Toàn vẹn:</strong> Nội dung không bị ai sửa đổi.</li>
                            <li>✅ <strong>Chống chối bỏ:</strong> Alice không thể chối là mình đã gửi thư.</li>
                        </ul>
                    </div>
                    <div class="space-y-3">
                        <h4 class="font-black text-indigo-400 text-xs uppercase">2. QUY TRÌNH KẾT HỢP (ALICE)</h4>
                        <p>Thuật toán ECDSA sẽ kết hợp <strong>Mã băm</strong> và <strong>Private Key</strong> (thứ chỉ Alice có) cùng một số ngẫu nhiên $(k)$ để tạo ra cặp số $(r, s)$. Cặp số này chính là Chữ ký số.</p>
                        <div class="p-3 bg-slate-950 rounded-xl border border-white/5 font-mono text-[10px] text-center italic">
                            (r, s) = SigEngine(Hash, PrivateKey, k)
                        </div>
                    </div>
                </div>

                <div class="pt-6 border-t border-white/5">
                    <h4 class="font-black text-cyan-500 text-xs mb-3 uppercase flex items-center gap-2">
                        VAI TRÒ CỦA PUBLIC KEY Ở BƯỚC 1
                    </h4>
                    <p class="mb-4">Khi Bob nhận được file kèm Chữ ký $(r, s)$, Bob dùng <strong>ECDSA Public Key</strong> của Alice để kiểm tra. Nếu phép toán khớp, Bob biết chắc 100% file an toàn. Ngược lại, nếu file bị sửa dù chỉ 1 byte, chữ ký sẽ vô hiệu ngay lập tức.</p>
                    <p class="text-xs italic bg-slate-950 p-4 rounded-xl border-l-4 border-cyan-500">
                        <strong>Lưu ý quan trọng:</strong> Alice không bao giờ gửi Private Key đi. Cô ấy chỉ gửi: File đã mã hóa + Chữ ký số + Public Key. Chữ ký ECDSA rất nhẹ, phù hợp cho mọi ứng dụng hiện đại.
                    </p>
                </div>
            </div>
        </details>
    </div>
  </div>
</SimulationLayout>

<script>
  import { signECDSA, bufferToHex } from '../utils/crypto.js';
  import { loadState, saveState } from '../utils/state.js';

  const actionBtn = document.getElementById('action-btn');
  const hashDisplay = document.getElementById('hash-display');
  const dDisplay = document.getElementById('d-display');
  const kDisplay = document.getElementById('k-display');
  const sigOutput = document.getElementById('sig-output');
  const statusTag = document.getElementById('status-tag');
  const engineCore = document.getElementById('engine-core');
  const engineGlow = document.getElementById('engine-glow');
  const engineIcon = document.getElementById('engine-icon');

  async function init() {
    const state = await loadState();
    if (state.hashHex) hashDisplay.textContent = state.hashHex.toUpperCase();

    if (state.signatureHex) {
        statusTag.textContent = "Đã ký ✅";
        statusTag.classList.replace("bg-amber-500/10", "bg-emerald-500/10");
        statusTag.classList.replace("text-amber-500", "text-emerald-500");

        dDisplay.textContent = "PRIVATE_KEY_SECURE_LOADED";
        dDisplay.classList.replace('text-slate-400', 'text-red-400');
        kDisplay.textContent = "k = [PREVIOUSLY_GENERATED]";
        kDisplay.classList.replace('text-slate-500', 'text-blue-400');

        sigOutput.textContent = state.signatureHex.toUpperCase();
        sigOutput.classList.remove('italic', 'text-slate-600');
        sigOutput.classList.add('text-white', 'font-black');

        actionBtn.innerHTML = `
          <span>TIẾP TỤC BƯỚC 5</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        `;
        actionBtn.classList.replace('bg-white', 'bg-purple-500');
        actionBtn.onclick = () => window.location.href = '/step5-encryption';
    }
  }

  actionBtn?.addEventListener('click', async () => {
    actionBtn.disabled = true;
    const state = await loadState();
    if (!state.keys.alice.ecdsa || !state.msg) {
        alert('Thiếu dữ liệu khóa hoặc thông điệp!');
        return;
    }

    statusTag.textContent = "Đang ký";
    statusTag.classList.replace("bg-amber-500/10", "bg-purple-500/10");
    statusTag.classList.replace("text-amber-500", "text-purple-500");

    // 1. Show inputs
    dDisplay.textContent = "PRIVATE_KEY_SECURE_LOADED";
    dDisplay.classList.replace('text-slate-400', 'text-red-400');
    await new Promise(r => setTimeout(r, 800));

    // 2. Generate k
    kDisplay.textContent = "k = " + bufferToHex(window.crypto.getRandomValues(new Uint8Array(8))).toUpperCase();
    kDisplay.classList.replace('text-slate-500', 'text-blue-400');
    await new Promise(r => setTimeout(r, 800));

    // 3. Engine Animation
    statusTag.textContent = "Đang tính toán (r, s)";
    engineCore.classList.add('scale-110');
    engineGlow.classList.add('opacity-30');
    engineIcon.classList.add('animate-spin');
    
    // Simulate math scramble
    for(let i=0; i<15; i++) {
        sigOutput.textContent = "(r: " + Math.random().toString(16).substring(2, 10) + ", s: " + Math.random().toString(16).substring(2, 10) + ")";
        await new Promise(r => setTimeout(r, 100));
    }

    // Actual Sign
    const signature = await signECDSA(state.keys.alice.ecdsa.privateKey, state.msg);
    const hex = bufferToHex(signature);

    state.signatureHex = hex;
    state.step = 5;
    await saveState(state);

    // Finalize
    engineCore.classList.remove('scale-110');
    engineGlow.classList.remove('opacity-30');
    engineIcon.classList.remove('animate-spin');
    
    sigOutput.textContent = hex.toUpperCase();
    sigOutput.classList.remove('italic', 'text-slate-600');
    sigOutput.classList.add('text-white', 'font-black');

    statusTag.textContent = "Đã ký ✅";
    statusTag.classList.replace("bg-purple-500/10", "bg-emerald-500/10");
    statusTag.classList.replace("text-purple-500", "text-emerald-500");

    actionBtn.innerHTML = `
      <span>TIẾP TỤC BƯỚC 5</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
    `;
    actionBtn.classList.replace('bg-white', 'bg-purple-500');
    actionBtn.disabled = false;
    actionBtn.onclick = () => window.location.href = '/step5-encryption';
  });

  window.addEventListener('DOMContentLoaded', init);
</script>
