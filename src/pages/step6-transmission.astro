---
import SimulationLayout from '../layouts/SimulationLayout.astro';
---

<SimulationLayout title="BƯỚC 6: Truyền tải & Tấn công - Crypto Wizard" currentStep={6}>
  <div class="space-y-8 pb-20">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-black text-white">BƯỚC 6: Truyền tải & Tấn công (MITM)</h1>
        <p class="text-slate-400">Gói tin đang bay qua môi trường mạng không an toàn. Hãy thử đóng vai Hacker!</p>
      </div>
       <div id="risk-badge" class="px-4 py-1.5 bg-red-500/10 border border-red-500/20 rounded-full text-[10px] font-black uppercase text-red-500 tracking-widest animate-pulse">
        Khu vực rủi ro cao (Eve is watching)
      </div>
    </div>

    <!-- Network Visualization Card -->
    <div class="step-card border-red-500/10 min-h-[480px] relative overflow-hidden flex flex-col items-center justify-between py-12">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(239,68,68,0.05),transparent)] pointer-events-none"></div>
        
        <!-- Network nodes -->
        <div class="w-full flex justify-between items-center px-16 relative z-10">
            <div class="flex flex-col items-center gap-3">
                <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-2xl flex items-center justify-center text-white font-black shadow-2xl border-4 border-white/10">A</div>
                <div class="text-[10px] font-black text-cyan-400 uppercase tracking-widest">ALICE</div>
            </div>
            
            <div class="flex flex-col items-center gap-3">
                <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center text-white font-black shadow-2xl border-4 border-white/10">B</div>
                <div class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">BOB</div>
            </div>
        </div>

        <!-- Animated Packet Path -->
        <div class="w-full px-16 relative h-48 flex items-center justify-center">
            <div class="absolute inset-x-16 h-px bg-gradient-to-r from-cyan-500 via-red-500/50 to-indigo-500 opacity-20"></div>
            
            <div id="packet" class="absolute left-16 w-24 h-32 bg-slate-900 border-2 border-white/10 rounded-3xl shadow-[0_0_40px_rgba(0,0,0,0.5)] flex flex-col items-center justify-center p-4 gap-3 transition-all duration-[4000ms] ease-in-out cursor-pointer group hover:border-red-500/50">
                <div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center text-cyan-400 group-hover:text-red-500 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <div class="text-[8px] font-black text-slate-500 uppercase tracking-widest text-center">Gói tin AES-GCM</div>
                <div class="flex gap-1">
                    <div id="led-1" class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                    <div id="led-2" class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse delay-75"></div>
                </div>
            </div>

            <!-- Hacker Icon (Eve) -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 flex flex-col items-center opacity-40 group/eve">
                <div class="w-12 h-12 bg-red-500/20 border border-red-500/40 rounded-full flex items-center justify-center text-red-500 animate-bounce">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3v-3.5L15.5 7.5z"/></svg>
                </div>
                <div class="text-[8px] font-black text-red-500 mt-2">HACKER (EVE)</div>
            </div>
        </div>

        <!-- Attack Controls -->
        <div class="relative z-20 space-y-4">
            <div id="intercept-msg" class="text-[10px] font-black text-slate-500 mb-4 transition-all opacity-0 tracking-widest uppercase">
                ⚠️ Đang chờ lệnh truyền tải...
            </div>
            
            <div class="flex flex-col md:flex-row justify-center gap-4">
                <button id="tamper-data-btn" class="flex-1 p-4 bg-red-500/10 border border-red-500/20 text-red-500 rounded-2xl hover:bg-red-500/20 transition-all flex flex-col items-center justify-center gap-1 group shadow-xl">
                  <div class="flex items-center gap-2 text-[11px] font-black uppercase">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      TẤN CÔNG DỮ LIỆU (TAMPER)
                  </div>
                  <div class="text-[9px] text-red-400/80 font-medium tracking-wide">MỤC TIÊU: Làm sai lệch nội dung</div>
                </button>
                <button id="tamper-sig-btn" class="flex-1 p-4 bg-amber-500/10 border border-amber-500/20 text-amber-500 rounded-2xl hover:bg-amber-500/20 transition-all flex flex-col items-center justify-center gap-1 group">
                  <div class="flex items-center gap-2 text-[11px] font-black uppercase">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M22 17H2"/><path d="M10 22h4"/><path d="M12 2v20"/><path d="m17 7-5-5-5 5"/></svg>
                      GIẢ MẠO CHỮ KÝ (FORGE)
                  </div>
                  <div class="text-[9px] text-amber-500/80 font-medium tracking-wide">MỤC TIÊU: Mạo danh người gửi</div>
                </button>
            </div>
        </div>
    </div>

    <!-- Status & Logic Area -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div id="tamper-status" class="p-6 rounded-3xl bg-slate-900 border border-white/5 flex flex-col items-center justify-center text-center space-y-4">
            <div id="status-icon" class="w-12 h-12 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
                <div class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Trình trạng gói tin</div>
                <div id="status-text" class="text-xs font-bold text-emerald-400">GÓI TIN ĐANG AN TOÀN TUYỆT ĐỐI.</div>
            </div>
        </div>

        <div class="p-6 rounded-3xl bg-blue-500/5 border border-blue-500/10 space-y-3">
             <div class="text-[10px] font-black text-blue-400 uppercase tracking-widest">Ghi chú bảo mật</div>
             <p class="text-[11px] text-slate-400 leading-relaxed italic text-justify">
                Ngay cả khi bị tấn công, kẻ xấu (Eve) cũng không thể đọc được nội dung vì AES đã mã hóa nó. Tuy nhiên, việc thay đổi dù chỉ 1 byte sẽ khiến chữ ký số ở bước sau bị vô hiệu. Đây là cách **Data Integrity** bảo vệ người dùng.
             </p>
        </div>
    </div>

    <!-- Action Button -->
    <div class="flex flex-col items-center gap-4 pt-4">
        <div class="flex flex-wrap justify-center gap-4">
            <button id="secure-btn" class="px-10 py-5 bg-emerald-500 text-slate-950 font-black rounded-2xl hover:bg-emerald-400 transition-all shadow-[0_0_40px_rgba(16,185,129,0.2)] flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m12 14 4-4"/><path d="m3.34 19 1.41-1.41"/><path d="M16 12h.01"/><path d="m21 3-8.5 8.5"/><path d="M21 3h-5.5"/><path d="M21 3v5.5"/><path d="m5.03 15.6-.36-.36a5 5 0 0 1 0-7.07l.71-.71a5 5 0 0 1 7.07 0l.36.36"/></svg>
                <span>GỬI AN TOÀN (SECURE SEND)</span>
            </button>
            <button id="action-btn" class="px-10 py-5 bg-white/10 hover:bg-white/20 text-white font-black rounded-2xl border border-white/10 transition-all flex items-center gap-3 group">
                <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span id="btn-text">GỬI THÔNG THƯỜNG</span>
            </button>
        </div>
        <p class="text-[9px] text-slate-500 uppercase tracking-widest font-black">Lưu ý: "Gửi thông thường" sẽ dễ bị Eve chặn và thay đổi dữ liệu</p>
    </div>

    <!-- Hacker Intercept Terminal (Eve's View) -->
    <div id="hacker-view" class="hidden animate-in fade-in slide-in-from-bottom-5 duration-700 bg-slate-950 border-2 border-red-500/30 rounded-[2.5rem] overflow-hidden shadow-[0_0_80px_rgba(239,68,68,0.15)]">
        <div class="bg-red-500/10 px-8 py-4 border-b border-red-500/20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></div>
                <span class="text-[10px] font-black tracking-widest text-red-500 uppercase">Eve's Intercept Terminal v2.1</span>
            </div>
            <div class="text-[9px] font-mono text-red-500/50">TARGET: Alice -> Bob | MODE: MAN-IN-THE-MIDDLE</div>
        </div>
        
        <div class="p-8 space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Ciphertext View -->
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <label class="text-[10px] font-black text-slate-500 uppercase">Raw Ciphertext (AES-GCM Payload)</label>
                        <span id="label-payload" class="text-[9px] px-2 py-0.5 bg-emerald-500/10 text-emerald-500 rounded border border-emerald-500/20">UNTOUCHED</span>
                    </div>
                    <div class="bg-black/40 p-5 rounded-2xl border border-white/5 font-mono text-xs break-all leading-relaxed relative overflow-hidden group">
                        <div id="hex-payload" class="text-slate-400 group-hover:text-slate-200 transition-colors">...</div>
                        <div id="payload-overlay" class="absolute inset-0 bg-red-500/0 pointer-events-none transition-colors duration-500"></div>
                    </div>
                    <div id="tamper-explain" class="hidden p-4 bg-red-500/10 border border-red-500/20 rounded-xl mt-2 animate-in fade-in slide-in-from-top-2">
                        <div class="text-[9px] font-black text-red-400 uppercase tracking-widest mb-1">MỤC ĐÍCH (TAMPER):</div>
                        <div class="text-[10px] text-red-300/80 leading-relaxed">Eve sửa đổi (lật bit) bản mã. Vì không có khóa AES nên cô ta không giải mã được, chỉ đoán mò để thay đổi giá trị gốc (ví dụ đổi số tiền chuyển khoản).</div>
                    </div>
                </div>

                <!-- Signature View -->
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <label class="text-[10px] font-black text-slate-500 uppercase">Alice's Digital Signature (ECDSA)</label>
                        <span id="label-sig" class="text-[9px] px-2 py-0.5 bg-emerald-500/10 text-emerald-500 rounded border border-emerald-500/20">VERIFIED</span>
                    </div>
                    <div class="bg-black/40 p-5 rounded-2xl border border-white/5 font-mono text-xs break-all leading-relaxed relative overflow-hidden group">
                        <div id="hex-sig" class="text-slate-400 group-hover:text-slate-200 transition-colors">...</div>
                        <div id="sig-overlay" class="absolute inset-0 bg-red-500/0 pointer-events-none transition-colors duration-500"></div>
                    </div>
                    <div id="forge-explain" class="hidden p-4 bg-amber-500/10 border border-amber-500/20 rounded-xl mt-2 animate-in fade-in slide-in-from-top-2">
                         <div class="text-[9px] font-black text-amber-500 uppercase tracking-widest mb-1">MỤC ĐÍCH (FORGE):</div>
                         <div class="text-[10px] text-amber-500/80 leading-relaxed">Eve ném bỏ chữ ký xịn và thay bằng chữ ký tự chế. Mục đích là đóng giả làm Alice để gửi các gói tin lừa đảo.</div>
                    </div>
                </div>
        </div>
    </div>

    <!-- Educational Accordion -->
    <div class="max-w-4xl mx-auto space-y-4">
        <details class="group bg-slate-900/50 border border-white/5 rounded-3xl overflow-hidden shadow-xl" open>
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-white/5 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center text-red-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                    </div>
                    <span class="font-black text-xs uppercase tracking-widest text-slate-200">Eve (Hacker) có thể làm gì?</span>
                </div>
                <svg class="w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="px-8 pb-8 space-y-8 text-sm text-slate-400 leading-relaxed text-justify md:columns-2 gap-12">
                <div class="space-y-3">
                    <h4 class="font-black text-red-400 text-xs uppercase">1. TẤN CÔNG BỊ ĐỘNG (Passive)</h4>
                    <p>Eve nghe lén đường truyền. Tuy nhiên, nhờ **AES-GCM (Bước 5)**, thông điệp đã biến thành một chuỗi ký tự ngẫu nhiên. Eve không có **Shared Secret** nên không thể giải mã.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-orange-400 text-xs uppercase">2. TẤN CÔNG CHỦ ĐỘNG (Active)</h4>
                    <p>Eve không đọc được, nhưng ả có thể sửa! Ví dụ: Eve thay đổi một vài bit trong bản mã. Nếu Bob không kiểm tra chữ ký ở bước sau, anh ta có thể nhận được một thông điệp sai lệch mà không hề hay biết.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-purple-400 text-xs uppercase">3. TẠI SAO AES-GCM LẠI AN TOÀN?</h4>
                    <p>Trong AES-GCM, một giá trị gọi là **Auth Tag** được đính kèm. Nó như một cái kẹp chì niêm phong. Nếu Eve sửa dữ liệu, kẹp chì này sẽ "vỡ" ngay khi Bob thử giải mã.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-emerald-400 text-xs uppercase">4. VAI TRÒ CỦA CHỮ KÝ (ECDSA)</h4>
                    <p>Dù Eve có giỏi đến mức giả mạo được mã băm, ả vẫn không thể tạo ra **Chữ ký số** khớp với Alice vì ả không có **Alice's Private Key**. Đây là lớp bảo vệ cuối cùng chống lại sự giả mạo.</p>
                </div>
            </div>
        </details>
    </div>
  </div>
</SimulationLayout>

<script>
  import { loadState, saveState } from '../utils/state.js';

  const actionBtn = document.getElementById('action-btn');
  const secureBtn = document.getElementById('secure-btn');
  const btnText = document.getElementById('btn-text');
  const packet = document.getElementById('packet');
  const interceptMsg = document.getElementById('intercept-msg');
  const tamperDataBtn = document.getElementById('tamper-data-btn');
  const tamperSigBtn = document.getElementById('tamper-sig-btn');
  const statusText = document.getElementById('status-text');
  const statusIcon = document.getElementById('status-icon');
  const leds = [document.getElementById('led-1'), document.getElementById('led-2')];
  
  const hackerView = document.getElementById('hacker-view');
  const hexPayload = document.getElementById('hex-payload');
  const hexSig = document.getElementById('hex-sig');
  const labelPayload = document.getElementById('label-payload');
  const labelSig = document.getElementById('label-sig');
  const payloadOverlay = document.getElementById('payload-overlay');
  const sigOverlay = document.getElementById('sig-overlay');

  const tamperExplain = document.getElementById('tamper-explain');
  const forgeExplain = document.getElementById('forge-explain');

  let isTransmitting = false;
  let isTamperedData = false;
  let isTamperedSig = false;
  let state = null;

  async function init() {
    state = await loadState();
    if (state.ciphertextHex) {
        hexPayload.textContent = state.ciphertextHex.toUpperCase();
        hexSig.textContent = state.signatureHex.toUpperCase();
    }

    if (state.step >= 7) {
        interceptMsg.textContent = "GÓI TIN ĐÃ TỚI ĐÍCH (BOB).";
        interceptMsg.classList.replace('opacity-0', 'opacity-100');
        interceptMsg.classList.add(state.isTamperedData || state.isTamperedSig ? 'text-red-500' : 'text-emerald-500');
        
        packet.style.left = 'calc(100% - 160px)';
        packet.style.opacity = '0';
        packet.style.transition = 'none';

        secureBtn.classList.remove('hidden');
        secureBtn.className = "px-10 py-5 bg-slate-800 text-white font-black rounded-2xl hover:bg-slate-700 transition-all flex items-center gap-3";
        secureBtn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          <span>THỬ LẠI TRUYỀN TẢI</span>
        `;
        secureBtn.onclick = async () => {
            state.step = 6;
            delete state.verdict;
            state.isTamperedData = false;
            state.isTamperedSig = false;
            await saveState(state);
            window.location.reload();
        };

        actionBtn.innerHTML = `
          <span>TỚI BƯỚC 7: XÁC THỰC</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        `;
        actionBtn.classList.replace('bg-white/10', 'bg-indigo-500');
        actionBtn.classList.add('text-white', 'px-16');
        actionBtn.onclick = () => window.location.href = '/step7-verification';

        if (state.isTamperedData || state.isTamperedSig) {
            isTamperedData = state.isTamperedData;
            isTamperedSig = state.isTamperedSig;
            updateStatus();
            hackerView.classList.remove('hidden');
            if (isTamperedData) {
                labelPayload.textContent = "CORRUPTED (BIT FLIP) ⚠️";
                labelPayload.className = "text-[9px] px-2 py-0.5 bg-red-500/20 text-red-500 rounded border border-red-500/30";
                
                let hex = state.ciphertextHex.toUpperCase();
                let before = hex.substring(0, 20);
                let after = hex.substring(22);
                hexPayload.innerHTML = `<span class="text-slate-500 opacity-50">${before}</span><span class="text-red-500 font-black bg-red-500/20 px-1 rounded animate-pulse">FF</span><span class="text-slate-500 opacity-50">${after}</span>`;
                tamperExplain.classList.remove('hidden');
            }
            if (isTamperedSig) {
                labelSig.textContent = "FORGED (REPLACED) ⚠️";
                labelSig.className = "text-[9px] px-2 py-0.5 bg-red-500/20 text-red-500 rounded border border-red-500/30";
                
                let fakeSig = "30440220" + "F".repeat(64);
                hexSig.innerHTML = `<span class="text-amber-500 font-black bg-amber-500/10 rounded animate-pulse px-2 block">${fakeSig}</span>`;
                forgeExplain.classList.remove('hidden');
            }
        }
    }
  }

  tamperDataBtn?.addEventListener('click', () => {
    isTamperedData = !isTamperedData;
    tamperDataBtn.classList.toggle('bg-red-500/50', isTamperedData);
    if (isTamperedData) {
        labelPayload.textContent = "CORRUPTED (BIT FLIP) ⚠️";
        labelPayload.className = "text-[9px] px-2 py-0.5 bg-red-500/20 text-red-500 rounded border border-red-500/30";
        payloadOverlay.className = "absolute inset-0 bg-red-500/10 pointer-events-none transition-colors duration-200 animate-pulse";
        
        let hex = state.ciphertextHex.toUpperCase();
        let before = hex.substring(0, 20);
        let after = hex.substring(22);
        hexPayload.innerHTML = `<span class="text-slate-500 opacity-50">${before}</span><span class="text-red-500 font-black bg-red-500/20 px-1 rounded animate-pulse">FF</span><span class="text-slate-500 opacity-50">${after}</span>`;
        tamperExplain.classList.remove('hidden');
    } else {
        labelPayload.textContent = "UNTOUCHED";
        labelPayload.className = "text-[9px] px-2 py-0.5 bg-emerald-500/10 text-emerald-500 rounded border border-emerald-500/20";
        payloadOverlay.className = "absolute inset-0 bg-red-500/0 pointer-events-none transition-colors duration-500";
        hexPayload.innerHTML = state.ciphertextHex.toUpperCase();
        tamperExplain.classList.add('hidden');
    }
    updateStatus();
  });

  tamperSigBtn?.addEventListener('click', () => {
    isTamperedSig = !isTamperedSig;
    tamperSigBtn.classList.toggle('bg-amber-500/50', isTamperedSig);
    if (isTamperedSig) {
        labelSig.textContent = "FORGED (REPLACED) ⚠️";
        labelSig.className = "text-[9px] px-2 py-0.5 bg-red-500/20 text-red-500 rounded border border-red-500/30";
        sigOverlay.className = "absolute inset-0 bg-amber-500/10 pointer-events-none transition-colors duration-200 animate-pulse";
        
        let fakeSig = "30440220" + "F".repeat(64);
        hexSig.innerHTML = `<span class="text-amber-500 font-black bg-amber-500/10 rounded animate-pulse px-2 block break-all">${fakeSig}</span>`;
        forgeExplain.classList.remove('hidden');
    } else {
        labelSig.textContent = "VERIFIED";
        labelSig.className = "text-[9px] px-2 py-0.5 bg-emerald-500/10 text-emerald-500 rounded border border-emerald-500/20";
        sigOverlay.className = "absolute inset-0 bg-red-500/0 pointer-events-none transition-colors duration-500";
        hexSig.innerHTML = state.signatureHex.toUpperCase();
        forgeExplain.classList.add('hidden');
    }
    updateStatus();
  });

  function updateStatus() {
    if (isTamperedData || isTamperedSig) {
        statusText.textContent = "CẢNH BÁO: GÓI TIN ĐÃ BỊ TẤN CÔNG ⚠️";
        statusText.className = "text-xs font-black text-red-500 animate-pulse";
        statusIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`;
        statusIcon.className = "w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center text-red-500";
        leds.forEach(l => l.classList.replace('bg-emerald-500', 'bg-red-500'));
    } else {
        statusText.textContent = "GÓI TIN ĐANG AN TOÀN TUYỆT ĐỐI.";
        statusText.className = "text-xs font-bold text-emerald-400";
        statusIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
        statusIcon.className = "w-12 h-12 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500";
        leds.forEach(l => l.classList.replace('bg-red-500', 'bg-emerald-500'));
    }
  }

  // Handle Secure Send (Bypass Eve)
  secureBtn?.addEventListener('click', async () => {
    if (isTransmitting) return;
    isTransmitting = true;
    secureBtn.disabled = true;
    actionBtn.disabled = true;
    
    // UI Update for secret tunnel
    interceptMsg.textContent = "🛡️ ĐANG SỬ DỤNG ĐƯỜNG TRUYỀN BẢO MẬT (BYPASSING EVE)...";
    interceptMsg.classList.replace('opacity-0', 'opacity-100');
    interceptMsg.classList.replace('text-slate-500', 'text-emerald-400');
    
    // Direct path animation
    packet.style.left = 'calc(100% - 160px)';
    packet.style.transitionDuration = '2000ms';
    packet.classList.add('shadow-[0_0_50px_rgba(16,185,129,0.5)]');
    
    await new Promise(r => setTimeout(r, 2000));
    packet.style.opacity = '0';

    // Force safe state
    if (!state) state = await loadState();
    state.isTamperedData = false;
    state.isTamperedSig = false;
    state.step = 7;
    delete state.verdict; // Reset step 7 verification status
    await saveState(state);

    finishTransmission();
  });

  // Handle Normal Transmit (Intercepted by Eve)
  actionBtn?.addEventListener('click', async () => {
    if (isTransmitting) return;
    isTransmitting = true;
    actionBtn.disabled = true;
    secureBtn.disabled = true;
    
    interceptMsg.textContent = "⚠️ GÓI TIN ĐANG DI CHUYỂN QUA MẠNG...";
    interceptMsg.classList.replace('opacity-0', 'opacity-100');
    interceptMsg.classList.add('animate-pulse');
    
    // Move to Middle
    packet.style.left = '45%';
    packet.style.transitionDuration = '2000ms';
    await new Promise(r => setTimeout(r, 2000));
    
    // Open Hacker Terminal
    hackerView.classList.remove('hidden');
    interceptMsg.textContent = "⚠️ GÓI TIN BỊ EVE CHẶN LẠI (INTERCEPTED)!";
    interceptMsg.classList.replace('text-slate-500', 'text-red-500');
    
    btnText.textContent = "TIẾP TỤC TRUYỀN TẢI";
    actionBtn.disabled = false;

    // Continue button
    actionBtn.onclick = async () => {
        hackerView.classList.add('opacity-50');
        interceptMsg.textContent = "⚠️ ĐANG GỬI GÓI TIN ĐẾN BOB...";
        interceptMsg.classList.replace('text-red-500', 'text-slate-500');
        
        packet.style.left = 'calc(100% - 160px)';
        packet.style.transitionDuration = '2000ms';
        await new Promise(r => setTimeout(r, 2000));
        packet.style.opacity = '0';

        if (!state) state = await loadState();
        state.isTamperedData = isTamperedData;
        state.isTamperedSig = isTamperedSig;
        state.step = 7;
        delete state.verdict; // Reset step 7 verification status
        await saveState(state);

        finishTransmission();
    };
  });

  function finishTransmission() {
    interceptMsg.textContent = "GÓI TIN ĐÃ TỚI ĐÍCH (BOB).";
    interceptMsg.classList.replace('text-slate-500', state.isTamperedData || state.isTamperedSig ? 'text-red-500' : 'text-emerald-500');
    interceptMsg.classList.remove('animate-pulse');

    // Combine buttons into one "Next Step" button
    secureBtn.classList.remove('hidden');
    secureBtn.className = "px-10 py-5 bg-slate-800 text-white font-black rounded-2xl hover:bg-slate-700 transition-all flex items-center gap-3";
    secureBtn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
      <span>THỬ LẠI TRUYỀN TẢI</span>
    `;
    secureBtn.disabled = false;
    secureBtn.onclick = async () => {
        state.step = 6;
        delete state.verdict;
        state.isTamperedData = false;
        state.isTamperedSig = false;
        await saveState(state);
        window.location.reload();
    };

    actionBtn.innerHTML = `
      <span>TỚI BƯỚC 7: XÁC THỰC</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
    `;
    actionBtn.classList.replace('bg-white/10', 'bg-indigo-500');
    actionBtn.classList.replace('text-white', 'hover:bg-indigo-400');
    actionBtn.classList.add('text-white', 'px-16');
    actionBtn.disabled = false;
    actionBtn.onclick = () => window.location.href = '/step7-verification';
  }

  window.addEventListener('DOMContentLoaded', init);
</script>
