---
import SimulationLayout from '../layouts/SimulationLayout.astro';
---

<SimulationLayout title="BƯỚC 1: Khởi tạo Khóa - Crypto Wizard" currentStep={1}>
  <div class="space-y-8 pb-20">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-black text-white">BƯỚC 1: Khởi tạo Cặp khóa</h1>
        <p class="text-slate-400">Quy trình kết hợp giữa sự ngẫu nhiên tuyệt đối và quy luật toán học chặt chẽ.</p>
      </div>
      <div id="status-tag" class="px-4 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full text-[10px] font-black uppercase text-amber-500 tracking-widest">
        Chờ bắt đầu
      </div>
    </div>

    <!-- Educational Math Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Part 1: Entropy -->
        <div class="step-card border-cyan-500/10 space-y-4">
            <div class="flex items-center justify-between">
                <div class="text-[10px] uppercase font-black tracking-widest text-cyan-400">1. Phần Ngẫu Nhiên (Entropy)</div>
                <div id="entropy-percent" class="text-[10px] font-mono text-cyan-400/50">0%</div>
            </div>
            <div class="h-32 bg-slate-950/50 rounded-2xl border border-white/5 relative overflow-hidden flex items-center justify-center">
                <canvas id="entropy-canvas" class="absolute inset-0 opacity-40"></canvas>
                <div id="entropy-msg" class="text-[10px] font-bold text-slate-500 text-center px-4 z-10 uppercase tracking-tighter">
                    Thu thập nhiễu hệ thống...
                </div>
            </div>
            <p class="text-[10px] text-slate-400 leading-relaxed italic">
                Máy tính lấy "nhiễu" từ hệ thống (chuột, nhiệt độ CPU...) để đảm bảo <strong>Private Key</strong> không thể đoán trước.
            </p>
        </div>

        <!-- Part 2: Formula -->
        <div class="flex flex-col items-center justify-center space-y-4 py-8">
            <div id="math-display" class="bg-slate-900 border border-white/5 p-6 rounded-3xl shadow-2xl relative group cursor-help transition-all hover:scale-105 active:scale-95">
                <div class="text-[9px] font-black text-indigo-400 absolute -top-3 left-4 bg-[#020617] px-2">TOÁN HỌC ĐƯỜNG CONG (ECC)</div>
                <div class="text-4xl md:text-5xl font-serif italic text-white flex items-center gap-3 tracking-tighter">
                    <span id="math-q" class="text-cyan-400 opacity-20">Q</span>
                    <span class="text-slate-700">=</span>
                    <span id="math-d" class="text-red-500 opacity-20">d</span>
                    <span class="text-slate-700">×</span>
                    <span id="math-g" class="text-indigo-400">G</span>
                </div>
                <!-- Tooltip Explanation -->
                <div class="absolute invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-300 bottom-full mb-3 left-1/2 -translate-x-1/2 w-72 p-4 bg-slate-900 border border-white/10 rounded-2xl text-[10px] text-slate-400 z-50 shadow-2xl pointer-events-none">
                    <div class="space-y-2">
                        <p><strong class="text-cyan-400">Q:</strong> Public Key (Điểm trên đường cong)</p>
                        <p><strong class="text-red-500">d:</strong> Private Key (Số nguyên ngẫu nhiên cực lớn)</p>
                        <p><strong class="text-indigo-400">G:</strong> Điểm cơ sở cố định (Base Point)</p>
                        <p class="pt-2 border-t border-white/5 italic">Phép nhân ở đây là phép nhân điểm trên đường cong Elliptic.</p>
                    </div>
                </div>
            </div>
            <div id="math-status" class="text-[10px] font-black text-slate-500 uppercase tracking-widest text-center">
                Đợi giá trị d...
            </div>
        </div>

        <!-- Part 3: Result Breakdown -->
        <div class="step-card border-indigo-500/10 space-y-4">
            <div class="text-[10px] uppercase font-black tracking-widest text-indigo-400">2. Phần Quy Luật (Toán học)</div>
            <div class="space-y-3">
                <div class="p-3 bg-slate-950 rounded-xl border border-white/5 space-y-1">
                    <div class="text-[8px] font-black text-slate-500">PRIVATE KEY (D)</div>
                    <div id="result-d" class="text-[10px] font-mono text-red-500/50 break-all truncate">****************</div>
                </div>
                <div class="p-3 bg-slate-950 rounded-xl border border-white/5 space-y-1">
                    <div class="text-[8px] font-black text-slate-500">PUBLIC KEY (Q)</div>
                    <div id="result-q" class="text-[10px] font-mono text-cyan-500/50 break-all truncate">****************</div>
                </div>
            </div>
            <p class="text-[10px] text-slate-400 leading-relaxed italic">
                Từ <strong>d</strong> tính ra <strong>Q</strong> rất nhanh, nhưng từ <strong>Q</strong> không thể tìm lại <strong>d</strong>.
            </p>
        </div>
    </div>

    <!-- Alice & Bob Summary Cards -->
    <div id="summary-section" class="grid grid-cols-1 md:grid-cols-2 gap-6 opacity-40 transition-opacity duration-700 pointer-events-none">
      <!-- Alice -->
      <div class="step-card border-cyan-500/20 group">
        <div class="absolute top-0 right-0 p-6 opacity-5 pointer-events-none">
           <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 bg-cyan-500 rounded-xl flex items-center justify-center text-slate-950 font-black text-lg">A</div>
          <h3 class="font-bold text-white">Alice (Sender)</h3>
        </div>
        <div id="alice-final" class="space-y-2">
            <div class="animate-pulse h-4 bg-white/5 rounded w-full"></div>
        </div>
      </div>

      <!-- Bob -->
      <div class="step-card border-indigo-500/20 group">
        <div class="absolute top-0 left-0 p-6 opacity-5 pointer-events-none">
           <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="flex items-center gap-4 mb-4 justify-end text-right">
          <h3 class="font-bold text-white">Bob (Receiver)</h3>
          <div class="w-10 h-10 bg-indigo-500 rounded-xl flex items-center justify-center text-slate-950 font-black text-lg">B</div>
        </div>
        <div id="bob-final" class="space-y-2">
            <div class="animate-pulse h-4 bg-white/5 rounded w-full"></div>
        </div>
      </div>
    </div>

    <div class="flex justify-center flex-col items-center gap-4">
       <button 
          id="action-btn"
          class="px-12 py-5 bg-white text-slate-950 font-black rounded-2xl hover:bg-cyan-400 transition-all shadow-2xl flex items-center gap-3 group"
        >
          <span>CHẠY QUY TRÌNH TOÁN HỌC</span>
          <svg class="group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </button>
    </div>

    <!-- Long Explanation Accordion (User's Text) -->
    <div class="max-w-4xl mx-auto space-y-4">
        <details class="group bg-slate-900/50 border border-white/5 rounded-3xl overflow-hidden shadow-xl" open>
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-white/5 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                    </div>
                    <span class="font-black text-xs uppercase tracking-widest text-slate-200">Tại sao các chuỗi khóa lại trông "loạn" như vậy?</span>
                </div>
                <svg class="w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="px-8 pb-8 space-y-6 text-sm text-slate-400 md:columns-2 gap-12 leading-relaxed text-justify">
                <div class="space-y-3">
                    <h4 class="font-black text-indigo-400 text-xs">1. PHẦN NGẪU NHIÊN (GỐC RỄ)</h4>
                    <p>Mọi cặp khóa đều bắt đầu từ một <strong>Private Key</strong>. Đây thực chất chỉ là một con số nguyên cực lớn được chọn ngẫu nhiên tuyệt đối.</p>
                    <p>Máy tính sử dụng các bộ sinh số ngẫu nhiên an toàn (<strong>CSPRNG</strong>), lấy "nhiễu" từ hệ thống (như chuyển động chuột, nhiệt độ CPU...) để đảm bảo số này không bao giờ trùng lặp và không thể đoán trước.</p>
                </div>
                <div class="space-y-3">
                    <h4 class="font-black text-indigo-400 text-xs">2. PHẦN QUY LUẬT (TOÁN HỌC)</h4>
                    <p>Public Key được tạo ra dựa trên quy luật toán học của Đường cong Elliptic (ECC) theo công thức: <code class="text-cyan-400 font-bold px-1">Q = d × G</code>.</p>
                    <p>Tính một chiều: Từ d và G tính ra Q rất nhanh, nhưng từ Q và G, kẻ tấn công cực kỳ khó để tìm lại d (bài toán Logarithm rời rạc cực khó).</p>
                </div>
                 <div class="md:col-span-2 pt-4 border-t border-white/5">
                    <p class="text-xs italic bg-slate-950 p-4 rounded-xl border-l-4 border-cyan-500">
                        <strong>Lưu ý:</strong> Các chuỗi bạn thấy (30593013...) trông giống nhau ở đoạn đầu vì chúng tuân theo quy luật đóng gói <strong>ASN.1</strong>. Nó giống như cái "vỏ hộp" để thông báo: "Đây là một khóa công khai thuộc loại Elliptic Curve". Phần "lõi" bên trong mới là phần ngẫu nhiên duy nhất.
                    </p>
                </div>
            </div>
        </details>
    </div>
  </div>
</SimulationLayout>

<script>
  import { generateECDHKeys, generateECDSAKeys, exportPublicKey, exportRawPublicKey, bufferToHex } from '../utils/crypto.js';
  import { loadState, saveState } from '../utils/state.js';

  const actionBtn = document.getElementById('action-btn');
  const statusTag = document.getElementById('status-tag');
  
  const canvas = document.getElementById('entropy-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  const entropyPercent = document.getElementById('entropy-percent');
  const entropyMsg = document.getElementById('entropy-msg');

  const mathQ = document.getElementById('math-q');
  const mathD = document.getElementById('math-d');
  const mathStatus = document.getElementById('math-status');

  const resultD = document.getElementById('result-d');
  const resultQ = document.getElementById('result-q');
  const summarySec = document.getElementById('summary-section');

  let isGenerating = false;

  function initCanvas() {
      if (!canvas) return;
      canvas.width = canvas.parentElement.clientWidth;
      canvas.height = canvas.parentElement.clientHeight;
  }

  function drawEntropy(progress) {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = "#22d3ee";
      for (let i = 0; i < progress * 100; i++) {
          ctx.beginPath();
          ctx.arc(Math.random() * canvas.width, Math.random() * canvas.height, 1, 0, Math.PI * 2);
          ctx.fill();
      }
  }

  async function init() {
    const state = await loadState();
    if (state.keys.alice.ecdh && state.keys.alice.ecdsa) {
        // Recover UI state
        statusTag.textContent = "Hoàn tất";
        statusTag.classList.replace("bg-amber-500/10", "bg-emerald-500/10");
        statusTag.classList.replace("text-amber-500", "text-emerald-500");

        const aliceRawECDH = await exportRawPublicKey(state.keys.alice.ecdh.publicKey);
        const aliceRawECDSA = await exportRawPublicKey(state.keys.alice.ecdsa.publicKey);
        const bobRawECDH = await exportRawPublicKey(state.keys.bob.ecdh.publicKey);

        resultD.textContent = "ALREADY GENERATED";
        resultD.classList.replace('text-red-500/50', 'text-red-500');
        
        resultQ.textContent = aliceRawECDH.substring(0, 16) + "...";
        resultQ.classList.replace('text-cyan-500/50', 'text-cyan-400');
        
        mathD.classList.replace('opacity-20', 'opacity-100');
        mathQ.classList.replace('opacity-20', 'opacity-100');
        mathStatus.textContent = "ECC Math Combined ✅";

        summarySec.classList.remove('opacity-40', 'pointer-events-none');
        document.getElementById('alice-final').innerHTML = `
            <div class="space-y-1">
                <div class="text-[8px] font-black text-cyan-500/50">ALICE ECDH (PUBLIC)</div>
                <div class="text-[9px] font-mono text-slate-400 break-all leading-tight bg-slate-950 p-2 rounded border border-white/5">
                    <span class="text-slate-600">3059...034200</span><span class="text-cyan-400">${aliceRawECDH.substring(0, 32)}...</span>
                </div>
            </div>
            <div class="space-y-1">
                <div class="text-[8px] font-black text-indigo-500/50">ALICE ECDSA (SIGNING)</div>
                <div class="text-[9px] font-mono text-slate-400 break-all leading-tight bg-slate-950 p-2 rounded border border-white/5">
                    <span class="text-slate-600">3059...034200</span><span class="text-indigo-400">${aliceRawECDSA.substring(0, 32)}...</span>
                </div>
            </div>
        `;

        document.getElementById('bob-final').innerHTML = `
            <div class="space-y-1">
                <div class="text-[8px] font-black text-cyan-500/50">BOB ECDH (PUBLIC)</div>
                <div class="text-[9px] font-mono text-slate-400 break-all leading-tight bg-slate-950 p-2 rounded border border-white/5 text-right">
                    <span class="text-slate-600">3059...034200</span><span class="text-cyan-400">${bobRawECDH.substring(0, 32)}...</span>
                </div>
            </div>
        `;

        actionBtn.innerHTML = `
          <span>TIẾP TỤC BƯỚC 2</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        `;
        actionBtn.classList.replace('bg-white', 'bg-cyan-500');
        actionBtn.onclick = () => window.location.href = '/step2-exchange';
    }
  }

  window.addEventListener('resize', initCanvas);
  initCanvas();
  init();

  actionBtn?.addEventListener('click', async () => {
    if (isGenerating) return;
    isGenerating = true;
    actionBtn.disabled = true;
    
    statusTag.textContent = "Đang tính toán";
    statusTag.classList.replace("bg-amber-500/10", "bg-cyan-500/10");
    statusTag.classList.replace("text-amber-500", "text-cyan-500");

    // --- STEP 1: ENTROPY ---
    entropyMsg.textContent = "Collecting Noise...";
    for (let p = 0; p <= 100; p += 2) {
        entropyPercent.textContent = p + "%";
        drawEntropy(p / 100);
        await new Promise(r => setTimeout(r, 20));
    }
    entropyMsg.textContent = "Entropy Gathered";
    entropyMsg.classList.add('text-cyan-400');

    // --- STEP 2: PRIVATE KEY (d) ---
    mathStatus.textContent = "Selecting Random d...";
    const rawD = window.crypto.getRandomValues(new Uint8Array(32));
    const dHex = bufferToHex(rawD);
    resultD.textContent = dHex.substring(0, 16) + "...";
    resultD.classList.replace('text-red-500/50', 'text-red-500');
    mathD.classList.replace('opacity-20', 'opacity-100');
    await new Promise(r => setTimeout(r, 1000));

    // --- STEP 3: COMPUTATION (Q = d x G) ---
    mathStatus.textContent = "Computing Q = d × G...";
    mathStatus.classList.add('animate-pulse', 'text-cyan-400');
    
    // Simulate complex point multiplication visually
    for (let i = 0; i < 10; i++) {
        resultQ.textContent = bufferToHex(window.crypto.getRandomValues(new Uint8Array(32))).substring(0, 16);
        await new Promise(r => setTimeout(r, 100));
    }

    // Actual key generation
    const state = await loadState();
    const aliceECDH = await generateECDHKeys();
    const aliceECDSA = await generateECDSAKeys();
    const bobECDH = await generateECDHKeys();

    // Export keys to JWK for state
    state.keys.alice.ecdh = aliceECDH;
    state.keys.alice.ecdsa = aliceECDSA;
    state.keys.bob.ecdh = bobECDH;
    state.step = Math.max(state.step, 2);
    await saveState(state);

    const aliceRawECDH = await exportRawPublicKey(aliceECDH.publicKey);
    const aliceRawECDSA = await exportRawPublicKey(aliceECDSA.publicKey);
    const bobRawECDH = await exportRawPublicKey(bobECDH.publicKey);

    resultQ.textContent = aliceRawECDH.substring(0, 16) + "...";
    resultQ.classList.replace('text-cyan-500/50', 'text-cyan-400');
    mathQ.classList.replace('opacity-20', 'opacity-100');
    mathStatus.textContent = "ECC Math Combined ✅";
    mathStatus.classList.remove('animate-pulse');

    // Show summary cards
    summarySec.classList.remove('opacity-40', 'pointer-events-none');
    
    document.getElementById('alice-final').innerHTML = `
        <div class="space-y-1">
            <div class="text-[8px] font-black text-cyan-500/50">ALICE ECDH (PUBLIC)</div>
            <div class="text-[9px] font-mono text-slate-400 break-all leading-tight bg-slate-950 p-2 rounded border border-white/5">
                <span class="text-slate-600">3059...034200</span><span class="text-cyan-400">${aliceRawECDH.substring(0, 32)}...</span>
            </div>
        </div>
        <div class="space-y-1">
            <div class="text-[8px] font-black text-indigo-500/50">ALICE ECDSA (SIGNING)</div>
            <div class="text-[9px] font-mono text-slate-400 break-all leading-tight bg-slate-950 p-2 rounded border border-white/5">
                <span class="text-slate-600">3059...034200</span><span class="text-indigo-400">${aliceRawECDSA.substring(0, 32)}...</span>
            </div>
        </div>
    `;

    document.getElementById('bob-final').innerHTML = `
        <div class="space-y-1">
            <div class="text-[8px] font-black text-cyan-500/50">BOB ECDH (PUBLIC)</div>
            <div class="text-[9px] font-mono text-slate-400 break-all leading-tight bg-slate-950 p-2 rounded border border-white/5 text-right">
                <span class="text-slate-600">3059...034200</span><span class="text-cyan-400">${bobRawECDH.substring(0, 32)}...</span>
            </div>
        </div>
    `;

    statusTag.textContent = "Hoàn tất";
    statusTag.classList.replace("bg-cyan-500/10", "bg-emerald-500/10");
    statusTag.classList.replace("text-cyan-500", "text-emerald-500");

    actionBtn.innerHTML = `
      <span>TIẾP TỤC BƯỚC 2</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
    `;
    actionBtn.classList.replace('bg-white', 'bg-cyan-500');
    actionBtn.disabled = false;
    actionBtn.onclick = () => window.location.href = '/step2-exchange';
  });
</script>
